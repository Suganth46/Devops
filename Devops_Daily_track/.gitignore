# .terraform.lock.hcl

# CLI configuration files
.terraformrc
terraform.rc

# Plan output files
*.tfplan

# Ignore provider plugin cache (if any custom paths used)
plugins/

# Ignore logs
*.log

# macOS / Linux / Windows junk files
.DS_Store
Thumbs.db